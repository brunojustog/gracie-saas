// Schema completo do domínio (fase 2/12).
//
// Multi-tenant por row-level isolation: toda tabela de domínio carrega
// `tenantId` e queries SEMPRE filtram por tenant (a checagem fica nos
// helpers de query da camada server, fase 3).
//
// Prisma 7: a `url` do datasource está em `prisma.config.ts`, não aqui.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────────────────────────────────────────
// Auth.js v5 (Adapter)
// ──────────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  emailVerified DateTime?
  image         String?
  isSuperAdmin  Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts          Account[]
  sessions          Session[]
  tenants           TenantUser[]
  assignedLeads     Lead[]         @relation("AssignedSeller")
  deletedLeads      Lead[]         @relation("DeletedLeadBy")
  movementsHistory  StageHistory[]
  salesAsSeller     Sale[]          @relation("SaleSeller")
  authoredLeadNotes LeadNote[]
  confirmedPayments PaymentRecord[] @relation("PaymentConfirmedBy")
  soldPrivatePackages PrivatePackage[] @relation("PrivatePackageSeller")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ──────────────────────────────────────────────────────────────────────────
// Tenancy
// ──────────────────────────────────────────────────────────────────────────

model Tenant {
  id           String   @id @default(cuid())
  slug         String   @unique
  name         String
  logoUrl      String?
  primaryColor String   @default("#C8102E")
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Plano de subscription (free/pro/enterprise) — irrelevante no MVP, mas
  // fica reservado para billing futuro.
  subscriptionPlan String?

  // Configuração da integração Chatwoot.
  //   - chatwootApiToken: outgoing (chamadas DA app PRA API do Chatwoot)
  //   - chatwootWebhookSecret: incoming (Chatwoot → app, validado via header
  //     X-Chatwoot-Webhook-Secret com timingSafeEqual)
  // Ambos devem ser cifrados em runtime antes de persistir. TODO antes do prod.
  chatwootUrl           String?
  chatwootAccountId     Int?
  chatwootApiToken      String?
  chatwootWebhookSecret String?
  /**
   * v1.1-U: filtro de import. Quando setado (não-nulo, não-vazio), só
   * conversas com essa label entram como lead (webhook + backfill).
   * Null/empty = importa todas as conversas (comportamento legado).
   */
  chatwootImportLabel   String?

  // Wuzapi (WhatsApp custom API) — usado pra disparar follow-up automatizado.
  //   - wuzapiUrl: URL base (ex: https://wuzapi.brunojusto.com.br)
  //   - wuzapiToken: token da INSTÂNCIA (header puro `token: <valor>` — não Bearer).
  //     Deve ser cifrado em runtime antes de persistir. TODO antes do prod.
  //   - followUpEnabled: master switch. Desligado, nenhum job dispara mesmo
  //     que existam no banco — útil pra pausar campanhas globalmente.
  wuzapiUrl             String?
  wuzapiToken           String?
  followUpEnabled       Boolean  @default(false)

  // ManyChat (chatbot Instagram/WhatsApp/Facebook). v1.1-AA: integração só
  // INCOMING (webhook). ManyChat não tem assinatura HMAC nativa — usamos
  // header customizado `X-Manychat-Secret` que o admin configura no External
  // Request da automação. Token vazio = sem validação (aceita qualquer POST
  // pra esse tenant — útil só pra dev/setup).
  manychatWebhookSecret String?
  /**
   * v1.1-AB: identificador da conta/página no ManyChat — é o trecho `fb...`
   * da URL quando logado (app.manychat.com/fb<id>/...). Com ele dá pra montar
   * o deep-link da conversa: app.manychat.com/fb<id>/chat/<subscriberId>.
   * Null = card cai no fallback do perfil do Instagram (ig_username).
   */
  manychatPageId        String?

  // Webhook genérico de leads do site (v1.1-AB). Mesmo modelo do ManyChat:
  // secret simples comparado com timingSafeEqual (header X-Site-Webhook-Secret
  // ou ?secret=). Vazio = aceita qualquer POST (só dev/setup).
  siteWebhookSecret     String?

  users               TenantUser[]
  leads               Lead[]
  modalities          Modality[]
  plans               Plan[]
  stages              Stage[]
  experimentalClasses ExperimentalClass[]
  enrollments         Enrollment[]
  webhookLogs         WebhookLog[]
  classSchedules      ClassSchedule[]
  messageJobs         MessageJob[]
  products            Product[]
  sales               Sale[]
  leadNotes           LeadNote[]
  paymentRecords      PaymentRecord[]
  privatePackages     PrivatePackage[]
}

enum Role {
  ADMIN
  MANAGER
  SELLER
}

model TenantUser {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String
  role      Role
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId])
}

// ──────────────────────────────────────────────────────────────────────────
// Catálogo (Stage / Modality / Plan)
// ──────────────────────────────────────────────────────────────────────────

model Stage {
  id       String  @id @default(cuid())
  tenantId String
  name     String
  color    String  @default("#6B7280")
  order    Int
  isWon    Boolean @default(false)
  isLost   Boolean @default(false)
  /**
   * v1.1-X: drag pra esse stage abre modal de agendar aula experimental
   * (se o lead ainda não tem aula futura). UX pra vendedora não precisar
   * sair do kanban.
   */
  isScheduling Boolean @default(false)
  /**
   * v1.1-Y: drag pra esse stage marca a aula futura mais próxima como
   * ATTENDED automaticamente. Reduz cliques pra registrar comparecimento.
   * No-op se o lead não tem aula SCHEDULED/CONFIRMED.
   */
  isAttendance Boolean @default(false)
  /**
   * v1.1-AR: estágio terminal de aula particular. Criar um pacote move o
   * lead pra cá automaticamente. NÃO conta como matrícula nem entra na
   * conversão de mensalistas (separado de isWon de propósito).
   */
  isPrivate Boolean @default(false)
  active   Boolean @default(true)

  tenant  Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leads   Lead[]
  history StageHistory[]

  @@unique([tenantId, order])
  @@index([tenantId])
}

model Modality {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  ageRange    String?
  /** Cor hex (#RRGGBB) usada no calendário pra pintar slots/aulas dessa modalidade. */
  color       String?
  /**
   * v1.1-AK: turma infantil. Usado no "Quadro do Vitor" pra separar
   * adultos × kids na contagem de alunos ativos. Backfill da migration:
   * true pras modalidades cujo nome começa com "GBK" (Gracie Barra Kids).
   * ADMIN ajusta o resto em Configurações → Modalidades.
   */
  isKids      Boolean  @default(false)
  active      Boolean  @default(true)

  tenant              Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plans               Plan[]
  leads               Lead[]
  experimentalClasses ExperimentalClass[]
  enrollments         Enrollment[]
  privatePackages     PrivatePackage[]
  classSchedules      ClassSchedule[]

  @@index([tenantId])
}

/**
 * Grade fixa: cada modalidade tem um conjunto de slots regulares (ex: GB1 toda
 * segunda 7h). Calendar usa pra desenhar background events e oferecer slots
 * pra agendar aulas experimentais.
 */
model ClassSchedule {
  id              String  @id @default(cuid())
  tenantId        String
  modalityId      String
  /** 0=domingo, 1=segunda, ..., 6=sábado (igual `Date.getDay()`). */
  dayOfWeek       Int
  /** Hora local da aula no formato "HH:MM" (sem timezone — academia tem fuso fixo). */
  startTime       String
  durationMinutes Int     @default(60)
  active          Boolean @default(true)

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  modality Modality @relation(fields: [modalityId], references: [id], onDelete: Cascade)

  @@index([tenantId, dayOfWeek])
}

model Plan {
  id           String   @id @default(cuid())
  tenantId     String
  modalityId   String?
  name         String
  monthlyValue Decimal  @db.Decimal(10, 2)
  setupFee     Decimal? @db.Decimal(10, 2)
  description  String?
  active       Boolean  @default(true)

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  modality    Modality?    @relation(fields: [modalityId], references: [id])
  enrollments Enrollment[]

  @@index([tenantId])
}

// ──────────────────────────────────────────────────────────────────────────
// Lead + Histórico de funil
// ──────────────────────────────────────────────────────────────────────────

enum LeadOrigin {
  WHATSAPP
  INSTAGRAM_DIRECT
  FACEBOOK
  WEBSITE
  REFERRAL
  WALK_IN
  PHONE
  GOOGLE_ADS
  // ── adicionados na v1.1 (canais que apareceram nas planilhas) ──
  MANYCHAT
  LINK_BIO
  PHONE_CALL
  HOSPITAL_PARTNERSHIP
  OTHER
}

/**
 * v1.1-AK: gênero do lead/aluno. Usado no "Quadro do Vitor" pra separar
 * Mulheres/Homens (adultos) e Meninas/Meninos (kids). Null = não informado
 * (cai num bucket "sem gênero" no quadro). Backfill da migration faz um
 * palpite pelo primeiro nome (pt-BR); ADMIN revisa na ficha do lead.
 */
enum Gender {
  FEMALE
  MALE
}

model Lead {
  id           String     @id @default(cuid())
  tenantId     String

  name         String
  phone        String?
  email        String?
  gender       Gender?
  /**
   * v1.1-AL: graduação (faixa) do aluno — vale pra lead, matrícula e aula
   * particular. `belt` guarda o nome da faixa ("Azul", "Cinza", …) e
   * `beltDegree` o nº de graus (0-4). Null = não informado. Usado pra ações
   * e ofertas por faixa.
   */
  belt         String?
  beltDegree   Int?
  origin       LeadOrigin @default(OTHER)
  originDetail String?

  // Chatwoot integration
  chatwootContactId      String?
  chatwootConversationId String?
  chatwootInboxId        Int?

  // ManyChat integration (v1.1-AA). Subscriber ID é o handle único do
  // contato dentro da página/conta ManyChat — usado pra dedup quando o
  // mesmo subscriber dispara vários eventos.
  manychatSubscriberId String?
  /**
   * v1.1-AB: @ do Instagram do subscriber (sem o @). Usado pro link da
   * conversa no card: deep-link do ManyChat quando o tenant configurou
   * manychatPageId, senão perfil instagram.com/<username>.
   */
  manychatIgUsername   String?

  // Comercial
  stageId          String
  modalityId       String?
  assignedSellerId String?
  potentialValue   Decimal? @db.Decimal(10, 2)
  notes            String?  @db.Text

  /**
   * Tags acumuláveis (orthogonais ao stage). Exemplos do playbook:
   *   "Contatado"      — primeira mensagem enviada mas sem resposta
   *   "Confirmado"     — confirmou comparecimento da aula
   *   "Remarcou"       — reagendou
   *   "VISITANTE GB"   — visitante de outra unidade GB
   *   "AVULSO"         — paga aula avulsa em vez de matrícula
   * Tags são strings livres pra permitir customização por tenant.
   */
  tags             String[] @default([])

  // Datas
  firstInteractionAt DateTime  @default(now())
  lastInteractionAt  DateTime  @default(now())
  nextActionAt       DateTime?

  /**
   * Override por-lead do follow-up automático. Independente do master switch
   * `Tenant.followUpEnabled` — quando false, nenhum job é criado pra esse
   * lead e os PENDING existentes são skipados.
   *
   * Default true: lead novo sempre entra na cadência (a menos que o tenant
   * inteiro esteja off). UI permite desligar manualmente quando o atendente
   * quer assumir 100% do follow.
   */
  followUpEnabled Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /**
   * Soft delete (v1.1-W). Lead some das queries normais mas fica no banco
   * pra auditoria e restauração via /settings/lixeira (ADMIN).
   * Bloqueado quando há enrollment ACTIVE — cancela matrícula primeiro.
   */
  deletedAt       DateTime?
  deletedById     String?
  deletionReason  String?   @db.Text

  tenant              Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stage               Stage               @relation(fields: [stageId], references: [id])
  modality            Modality?           @relation(fields: [modalityId], references: [id])
  assignedSeller      User?               @relation("AssignedSeller", fields: [assignedSellerId], references: [id])
  deletedBy           User?               @relation("DeletedLeadBy", fields: [deletedById], references: [id])
  history             StageHistory[]
  experimentalClasses ExperimentalClass[]
  enrollment          Enrollment?
  messageJobs         MessageJob[]
  sales               Sale[]
  leadNotes           LeadNote[]
  privatePackages     PrivatePackage[]

  @@index([tenantId])
  @@index([tenantId, stageId])
  @@index([tenantId, assignedSellerId])
  @@index([tenantId, deletedAt])
  @@index([chatwootContactId])
  @@index([manychatSubscriberId])
}

model StageHistory {
  id          String   @id @default(cuid())
  leadId      String
  fromStageId String?
  toStageId   String
  changedById String?
  notes       String?
  changedAt   DateTime @default(now())

  lead      Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  toStage   Stage @relation(fields: [toStageId], references: [id])
  changedBy User? @relation(fields: [changedById], references: [id])

  @@index([leadId])
}

// ──────────────────────────────────────────────────────────────────────────
// Histórico de observações + eventos (v1.1-L) — "diário" do lead/aluno
// ──────────────────────────────────────────────────────────────────────────

/**
 * Tipos de entrada no diário. `MANUAL` = observação escrita pelo
 * atendente; o resto são eventos automáticos plugados nas server actions
 * relevantes (matricula, follow-up, aulas, chatwoot, stage change).
 *
 * Adicionar novos kinds aqui é seguro — render padrão (kind + body)
 * funciona pra qualquer um; UI pode customizar ícone/cor opcionalmente.
 */
enum LeadNoteKind {
  MANUAL
  STAGE_CHANGED
  ENROLLMENT_CREATED
  ENROLLMENT_UPDATED
  ENROLLMENT_SUSPENDED
  ENROLLMENT_REACTIVATED
  ENROLLMENT_CANCELED
  CLASS_SCHEDULED
  CLASS_ATTENDED
  CLASS_NO_SHOW
  CLASS_RESCHEDULED
  CLASS_CANCELED
  WHATSAPP_REPLY
  FOLLOWUP_PAUSED
  FOLLOWUP_RESUMED
  LEAD_CREATED
  LEAD_DELETED
  LEAD_RESTORED
  // v1.1-AA: eventos vindos do ManyChat (tag aplicada, resposta de flow,
  // conversa iniciada/encerrada). subscriber_created não escreve note —
  // a própria criação do Lead já marca o início.
  MANYCHAT_EVENT
  // v1.1-AB: pagamento de mensalidade confirmado (PaymentRecord criado).
  PAYMENT_CONFIRMED
  // v1.1-AL: registro de cobrança (ação tomada pela equipe de cobrança
  // sobre um inadimplente). Vira histórico no diário do lead.
  COLLECTION_NOTE
  // v1.1-AO: eventos de pacote de aulas particulares.
  PRIVATE_PACKAGE_CREATED
  PRIVATE_PACKAGE_COMPLETED
  PRIVATE_PACKAGE_CANCELED
}

/**
 * 1 row por entrada no diário do lead. Cronologia reversa na UI.
 *
 * `authorId` é null para eventos do sistema (ex: lead respondeu via
 * webhook do Chatwoot — não tem usuário humano por trás).
 *
 * `body` é o texto renderizado para exibição direta. Pode incluir o nome
 * do autor original ("Bruno congelou a matrícula") ou só o fato seco
 * ("Lead respondeu no WhatsApp") — o conteúdo é congelado no momento do
 * evento, não re-renderiza se o nome mudar depois.
 *
 * `metadata` é JSON opcional com dados estruturados que a UI pode usar
 * pra detalhes (ex: { fromStage: "Novo Lead", toStage: "Potencial" }).
 */
model LeadNote {
  id        String       @id @default(cuid())
  tenantId  String
  leadId    String
  authorId  String?
  kind      LeadNoteKind
  body      String       @db.Text
  metadata  Json?
  createdAt DateTime     @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  author User?  @relation(fields: [authorId], references: [id])

  @@index([leadId, createdAt])
  @@index([tenantId, kind])
}

// ──────────────────────────────────────────────────────────────────────────
// Aulas Experimentais
// ──────────────────────────────────────────────────────────────────────────

enum ExperimentalClassStatus {
  SCHEDULED
  CONFIRMED
  ATTENDED
  NO_SHOW
  RESCHEDULED
  CANCELED
}

model ExperimentalClass {
  id            String                  @id @default(cuid())
  tenantId      String
  leadId        String
  modalityId    String
  scheduledDate DateTime
  status        ExperimentalClassStatus @default(SCHEDULED)
  notes         String?
  attendedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead        Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  modality    Modality     @relation(fields: [modalityId], references: [id])
  messageJobs MessageJob[]

  @@index([tenantId, scheduledDate])
  @@index([leadId])
}

// ──────────────────────────────────────────────────────────────────────────
// Matrículas
// ──────────────────────────────────────────────────────────────────────────

enum PaymentMethod {
  CREDIT_CARD
  PIX
  BOLETO
  CASH
  TRANSFER
  OTHER
}

enum EnrollmentStatus {
  ACTIVE
  CANCELED
  SUSPENDED // legado (v1.1-AT): congelado NÃO usa mais status — ver doc abaixo
  /**
   * v1.1-AU: aluno que sumiu devendo, não rescindiu (não pagou multa) e foi
   * dado como perda. Sai dos ativos, CONTA como cancelamento no total, mas
   * fica numa carteira separada pra cobrança jurídica (fora dos inadimplentes
   * recuperáveis do dia-a-dia).
   */
  JUDICIAL
}

model Enrollment {
  id            String           @id @default(cuid())
  tenantId      String
  leadId        String           @unique
  modalityId    String
  planId        String
  status        EnrollmentStatus @default(ACTIVE)
  enrolledAt    DateTime         @default(now())
  canceledAt    DateTime?
  monthlyValue  Decimal          @db.Decimal(10, 2)
  paymentMethod PaymentMethod
  observations  String?          @db.Text

  /**
   * Congelamento (v1.1-AT, redesenhado). REGRA NOVA: congelar é pra aluno
   * com atestado (doença) ou férias e NÃO muda o status — a matrícula segue
   * ACTIVE, continua contando como aluno ativo e continua sendo cobrada
   * (não pausa vencimento). O sistema só acumula os DIAS congelados pra
   * repor ao final do contrato.
   *
   *   - suspendedAt: início do congelamento atual (null = não está congelado).
   *     "Congelado agora" = status ACTIVE && suspendedAt != null.
   *   - suspensionReason: motivo livre.
   *   - frozenKind: "DOENCA" (limite = tempo do atestado) ou "FERIAS" (limite 30d).
   *   - expectedReturnAt: retorno previsto.
   *   - frozenDaysUsed: total acumulado de dias já congelados (somado a cada
   *     descongelamento) — é o que deve ser reposto no fim do contrato.
   *   - contractEndAt: fim do contrato; ao descongelar, é estendido pelos
   *     dias congelados. Null = sem data de fim (ex: mensal recorrente) —
   *     nesse caso só o frozenDaysUsed importa como "dias a repor".
   */
  suspendedAt      DateTime?
  suspensionReason String?
  frozenKind       String?
  expectedReturnAt DateTime?
  frozenDaysUsed   Int       @default(0)
  contractEndAt    DateTime?

  /**
   * v1.1-AB: próximo vencimento da mensalidade. Confirmar um pagamento
   * (PaymentRecord) avança essa data +1 mês (ancorado no dia do mês).
   * "Inadimplente" é derivado: status ACTIVE && nextDueDate < hoje.
   * Backfill da migration: dia do mês de `enrolledAt`, no ciclo corrente
   * ou seguinte. Null = sem controle de vencimento (matrículas antigas
   * canceladas, p.ex.).
   */
  nextDueDate DateTime?

  /**
   * v1.1-BB: quitação total (aluno pagou vários meses/ano de uma vez).
   * Enquanto `paidInFullUntil >= hoje`, a matrícula NÃO entra na receita
   * mensal recorrente (o valor já foi recebido de uma vez) e o nextDueDate
   * é empurrado pra essa data (some dos vencimentos/inadimplência). Null =
   * mensalista normal mês a mês.
   */
  paidInFullUntil DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead     Lead     @relation(fields: [leadId], references: [id])
  modality Modality @relation(fields: [modalityId], references: [id])
  plan     Plan     @relation(fields: [planId], references: [id])
  payments PaymentRecord[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, status, nextDueDate])
}

/**
 * v1.1-AB: 1 row por pagamento de mensalidade confirmado manualmente
 * (vendedora clica "Confirmar pagamento" na tela de matrículas).
 *
 * `amount` é snapshot do monthlyValue no momento da confirmação — reajuste
 * de plano depois não reescreve o histórico. `dueDate` é o vencimento que
 * esse pagamento quitou (o nextDueDate vigente na hora).
 */
model PaymentRecord {
  id            String         @id @default(cuid())
  tenantId      String
  enrollmentId  String
  /** Vencimento quitado por esse pagamento (null se a matrícula não tinha vencimento). */
  dueDate       DateTime?
  paidAt        DateTime       @default(now())
  amount        Decimal        @db.Decimal(10, 2)
  method        PaymentMethod?
  confirmedById String?
  notes         String?

  createdAt DateTime @default(now())

  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  enrollment  Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  confirmedBy User?      @relation("PaymentConfirmedBy", fields: [confirmedById], references: [id])

  @@index([tenantId, paidAt])
  @@index([enrollmentId])
}

// ──────────────────────────────────────────────────────────────────────────
// Aulas particulares (v1.1-AO) — pacotes avulsos, NÃO contam como matrícula
// ──────────────────────────────────────────────────────────────────────────

enum PrivatePackageStatus {
  ACTIVE     // pacote em andamento (aulas a dar)
  COMPLETED  // todas as aulas contratadas foram concluídas
  CANCELED   // cancelado antes de concluir
}

/**
 * Pacote de aulas particulares comprado por um aluno NÃO-mensalista.
 *
 * Decisão de produto: esses alunos seguem no kanban como leads (processo
 * comercial normal) mas NUNCA viram Enrollment — pra não inflar a contagem
 * de matriculados. Um lead pode ter VÁRIOS pacotes ao longo do tempo
 * (compra, termina, compra de novo).
 *
 * Progresso: `totalClasses` contratadas vs sessões concluídas (PrivateSession
 * com completedAt). Quando concluídas == contratadas → status COMPLETED.
 * `value` é a receita do pacote (entra na receita global do Quadro do Vitor).
 */
model PrivatePackage {
  id            String               @id @default(cuid())
  tenantId      String
  leadId        String
  modalityId    String?
  totalClasses  Int
  value         Decimal              @db.Decimal(10, 2)
  paymentMethod PaymentMethod?
  status        PrivatePackageStatus @default(ACTIVE)
  startDate     DateTime             @default(now())
  endDate       DateTime?            // previsão/limite de término
  canceledAt    DateTime?
  soldById      String?              // vendedora que fechou (User)
  notes         String?              @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead     Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  modality Modality?        @relation(fields: [modalityId], references: [id])
  soldBy   User?            @relation("PrivatePackageSeller", fields: [soldById], references: [id])
  sessions PrivateSession[]

  @@index([tenantId, status])
  @@index([leadId])
}

/**
 * 1 aula dentro de um pacote particular. `scheduledDate` = data agendada;
 * `completedAt` = quando a aula foi efetivamente dada (null = ainda não).
 */
model PrivateSession {
  id            String    @id @default(cuid())
  packageId     String
  scheduledDate DateTime?
  completedAt   DateTime?
  notes         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  package PrivatePackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@index([packageId])
}

// ──────────────────────────────────────────────────────────────────────────
// Integrações
// ──────────────────────────────────────────────────────────────────────────

// ──────────────────────────────────────────────────────────────────────────
// Mensagens automáticas (v1.1)
// ──────────────────────────────────────────────────────────────────────────

enum MessageJobStatus {
  PENDING   // agendado, ainda não disparou
  SENT      // enviado com sucesso
  SKIPPED   // cancelado (lead respondeu / mudou de stage / tenant desativou)
  FAILED    // erro permanente no envio (Wuzapi 4xx/5xx — retry manual)
}

/**
 * 1 row por mensagem agendada (Etapa Novo Lead M1..M8, lembretes de
 * agendamento, mensagem pós-comparecimento, etc).
 *
 * `templateKey` é o slug semântico ("welcome.m1", "appointment.confirm",
 * "appointment.d-1", "appointment.no-show-1", "attendance.post").
 *
 * `experimentalClassId` opcional: jobs ligados a uma AE específica (lembretes
 * de agendamento) referenciam aqui — quando a AE é cancelada/reagendada, esses
 * jobs caem em cascade. Welcome (etapa Novo Lead) não tem AE, fica null.
 *
 * Cron horário busca `status=PENDING AND scheduledAt <= now()`, envia via
 * Wuzapi, marca SENT.
 */
model MessageJob {
  id                  String           @id @default(cuid())
  tenantId            String
  leadId              String
  experimentalClassId String?          // null pra jobs não ligados a uma AE
  templateKey         String           // ex: "welcome.m1", "appointment.confirm"
  scheduledAt         DateTime
  status              MessageJobStatus @default(PENDING)
  sentAt              DateTime?
  errorMessage        String?          @db.Text
  /** Snapshot do texto renderizado no momento do envio — útil pra auditoria. */
  renderedBody        String?          @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead              Lead               @relation(fields: [leadId], references: [id], onDelete: Cascade)
  experimentalClass ExperimentalClass? @relation(fields: [experimentalClassId], references: [id], onDelete: Cascade)

  /**
   * Idempotência: pra um mesmo lead, mesma key e mesma AE só pode existir 1
   * row. NULL não match NULL em PG — pra welcome (sem AE) o enqueue checa
   * manualmente antes de inserir.
   */
  @@unique([leadId, templateKey, experimentalClassId])
  @@index([tenantId, status, scheduledAt])
  @@index([leadId])
  @@index([experimentalClassId])
}

model WebhookLog {
  id        String   @id @default(cuid())
  tenantId  String
  source    String
  eventType String
  payload   Json
  processed Boolean  @default(false)
  error     String?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, processed])
  @@index([createdAt])
}

// ──────────────────────────────────────────────────────────────────────────
// Lojinha / PDV (v1.1-I)
// ──────────────────────────────────────────────────────────────────────────

enum ProductCategory {
  BEBIDA
  SUPLEMENTO
  KIMONO
  FAIXA
  CAMISETA
  RASHGUARD
  BERMUDA_SHORT
  ACESSORIO
  OUTRO
}

/**
 * Produto-pai. Sempre tem >=1 ProductVariant. Quando o produto não tem
 * variação real (ex: lata de Red Bull), uma variant única "Padrão" é criada
 * pra manter o modelo uniforme — assim a venda sempre referencia uma variant
 * (com preço + estoque próprios).
 */
model Product {
  id          String          @id @default(cuid())
  tenantId    String
  name        String
  category    ProductCategory @default(OUTRO)
  description String?
  active      Boolean         @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  variants ProductVariant[]

  @@index([tenantId, active])
  @@index([tenantId, category])
}

/**
 * Variant é a unidade vendável: tem preço, estoque e SKU próprios.
 *
 * `stock` nullable = ilimitado (vende sempre, não decrementa). Útil pra
 * cortesia ou itens que o tenant não quer controlar saldo.
 *
 * `label` é o discriminador humano dentro do produto: "A2" (faixa), "M"
 * (camiseta), "GB1 - G" (kimono), "Padrão" (sem variação real).
 */
model ProductVariant {
  id        String   @id @default(cuid())
  productId String
  label     String
  sku       String?
  price     Decimal  @db.Decimal(10, 2)
  /** null = estoque ilimitado; integer = saldo controlado (decrementa por venda). */
  stock     Int?
  active    Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product   Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  saleItems SaleItem[]

  @@unique([productId, label])
  @@index([productId, active])
}

enum SalePaymentMethod {
  PIX
  DINHEIRO
  CARTAO_DEBITO
  CARTAO_CREDITO
  CORTESIA
  OUTRO
}

/**
 * 1 venda na lojinha. Quem vendeu (sellerUserId) é o User logado no momento;
 * customerLeadId é opcional (venda avulsa = visitante / cliente sem cadastro).
 *
 * `total` é o snapshot do total no momento do fechamento — soma dos
 * SaleItem.subtotal (que por sua vez tem `unitPrice` congelado). Reajustar
 * preço do produto depois NÃO altera vendas antigas.
 */
model Sale {
  id             String            @id @default(cuid())
  tenantId       String
  sellerUserId   String
  customerLeadId String?
  total          Decimal           @db.Decimal(10, 2)
  paymentMethod  SalePaymentMethod
  paidAt         DateTime          @default(now())
  notes          String?           @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sellerUser   User       @relation("SaleSeller", fields: [sellerUserId], references: [id])
  customerLead Lead?      @relation(fields: [customerLeadId], references: [id])
  items        SaleItem[]

  @@index([tenantId, paidAt])
  @@index([tenantId, sellerUserId])
  @@index([customerLeadId])
}

model SaleItem {
  id               String  @id @default(cuid())
  saleId           String
  productVariantId String
  quantity         Int
  /** Preço unitário congelado no momento da venda (snapshot pra histórico imutável). */
  unitPrice        Decimal @db.Decimal(10, 2)
  subtotal         Decimal @db.Decimal(10, 2)

  sale           Sale           @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productVariant ProductVariant @relation(fields: [productVariantId], references: [id])

  @@index([saleId])
  @@index([productVariantId])
}
